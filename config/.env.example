#!/usr/bin/env bash
# Used as a default to seed config/.env which
# enables you to use environment variables to configure
# the aspects of your application that vary by
# environment.
#
# To use this file, first copy it into `config/.env`. Also ensure the related
# code block for loading this file is uncommented in `config/bootstrap.php`
#
# For DDEV: Copy this to .env and update SECURITY_SALT
export APP_NAME="tinyauth-demo"
export DEBUG="true"
export APP_ENCODING="UTF-8"
export APP_DEFAULT_LOCALE="en_US"
export APP_DEFAULT_TIMEZONE="UTC"

# SECURITY: Set your full base URL (required for DDEV)
export APP_FULL_BASE_URL="https://tinyauth-demo.ddev.site:33001"

# SECURITY: Generate a unique salt for your installation
# You can generate one with: php -r "echo bin2hex(random_bytes(32));"
export SECURITY_SALT="__REPLACE_WITH_YOUR_SALT__"

# Email transport (DDEV Mailpit)
export EMAIL_TRANSPORT_DEFAULT_URL="smtp://localhost:1025"

# Database configuration (DDEV defaults)
export DATABASE_URL="mysql://db:db@db:3306/db"

# For DebugKit to work with .site TLD
export DEBUG_KIT_SAFE_TLD="site"
